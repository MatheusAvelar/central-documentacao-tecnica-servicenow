<xml><![CDATA[<?xml version="1.0" encoding="utf-8"?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide">

    <div id="tab-review" class="tab-content">

        <!-- ====================== -->
        <!--        ESTILOS         -->
        <!-- ====================== -->
        <style>
            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 20px;
