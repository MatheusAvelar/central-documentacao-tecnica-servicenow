            }

            tr.passou td {
                background-color: #DFF0D8 !important;
            }

            tr.nao-passou td {
                background-color: #F8D7DA !important;
            }

            .table-responsive {
                width: 100%;
                overflow-x: auto;
                margin-top: 20px;
            }

            input[type="text"] {
                width: 100%;
                padding: 8px;
